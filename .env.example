# Convex
# These are auto-generated when you run `bunx convex dev`
CONVEX_DEPLOYMENT=dev:your-deployment-name
VITE_CONVEX_URL=https://your-deployment.convex.cloud
VITE_CONVEX_SITE_URL=https://your-deployment.convex.site

# Clerk Authentication
# Get these from https://dashboard.clerk.com/last-active?path=api-keys
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key
CLERK_SECRET_KEY=sk_test_your_secret_key
CLERK_JWT_ISSUER_DOMAIN=https://your-app.clerk.accounts.dev

# Gemini API Key
# Get this from https://aistudio.google.com/app/apikey
# Set with: bunx convex env set GEMINI_API_KEY your-key
# This should NOT be in .env.local - set it in Convex directly